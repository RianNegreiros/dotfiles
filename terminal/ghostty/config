theme = dracula
background = #282a36
foreground = #f8f8f2
selection-background = #44475a
selection-foreground = #ffffff
cursor-color = #f8f8f2
cursor-text = #282a36
palette = 0=#21222c
palette = 1=#ff5555
palette = 2=#50fa7b
palette = 3=#f1fa8c
palette = 4=#bd93f9
palette = 5=#ff79c6
palette = 6=#8be9fd
palette = 7=#f8f8f2
palette = 8=#6272a4
palette = 9=#ff6e6e
palette = 10=#69ff94
palette = 11=#ffffa5
palette = 12=#d6acff
palette = 13=#ff92df
palette = 14=#a4ffff
palette = 15=#ffffff

background-opacity = 0.85
background-blur = true
window-decoration = true
font-family = "JetBrains Mono"

# Enable VSync
# Options: Boolean
window-vsync = true

# Confirm before closing
# Options: Boolean
confirm-close-surface = true

# Trim spaces when copying
# Options: Boolean
clipboard-trim-trailing-spaces = true

# Paste protection warning
# Options: Boolean
clipboard-paste-protection = true

# Safe bracketed paste
# Options: Boolean
clipboard-paste-bracketed-safe = true

# Allow desktop notifications
# Options: Boolean
desktop-notifications = true

# Wide tabs
# Options: Boolean
gtk-wide-tabs = true

# Show GTK titlebar
# Options: Boolean
gtk-titlebar = false

# Auto-hide on focus lost
# Options: Boolean
quick-terminal-autohide = true

window-padding-x = 4
window-padding-y = 8

# Window height in cells
# Options: Number
window-height = 36

# Window width in cells
# Options: Number
window-width = 160
